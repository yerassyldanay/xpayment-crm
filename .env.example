# xpayment-crm — environment catalog (docs/05-configuration.md).
# Copy to .env and fill in. .env is gitignored; never put secrets here.

# Runtime / HTTP
APP_ENV=dev
LOG_LEVEL=info
HTTP_ADDR=:8080
METRICS_TOKEN=

# Store (embedded SQLite — put on a persistent volume in prod)
DB_PATH=./data/brain.db

# LLM (OpenRouter, provider-neutral — Decision 13). LLM_API_KEY is REQUIRED.
LLM_API_KEY=
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=anthropic/claude-sonnet-4
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.3

# Chatwoot (the hub) — all REQUIRED
CHATWOOT_BASE_URL=
CHATWOOT_ACCOUNT_ID=
CHATWOOT_API_TOKEN=
CHATWOOT_INBOX_ID=
CHATWOOT_WEBHOOK_SECRET=

# Admin UI — ADMIN_PASSWORD and SESSION_SECRET are REQUIRED
ADMIN_USER=admin
ADMIN_PASSWORD=
SESSION_SECRET=

# Media
MEDIA_DIR=./data/media
MEDIA_BASE_URL=

# Observability (OTel)
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=xpayment-crm
OTEL_SAMPLE_RATE=1.0

# ── Docker stack only (docker-compose.yml) — not read by the Go app ───────────
# Generate: SECRET_KEY_BASE=$(openssl rand -hex 64)  AUTHENTICATION_API_KEY=$(openssl rand -hex 16)
SECRET_KEY_BASE=
AUTHENTICATION_API_KEY=

# ── Existing Postgres/Redis to REUSE (compose interpolates these) ──────────────
# Chatwoot and Evolution connect to your EXISTING Postgres/Redis — the compose has
# no bundled databases. Containers reach a host-published service via
# host.docker.internal (extra_hosts maps it to the docker host gateway).
#
# Example values target the LOCAL existing services:
#   - Postgres: kaspi-service-db (pgvector pg16) published on host port 54321
#   - Redis:    kaspim-redis published on host port 6379 (0/1/6 are in use — pick a free index)
# For the REMOTE server, set host/port/credentials to that server's PG/Redis.
#
# One-time setup on the existing Postgres (see RUNBOOK.md):
#   CREATE ROLE chatwoot  LOGIN PASSWORD '...';  CREATE DATABASE chatwoot  OWNER chatwoot;
#   CREATE ROLE evolution LOGIN PASSWORD '...';  CREATE DATABASE evolution OWNER evolution;
#   \c chatwoot ; CREATE EXTENSION IF NOT EXISTS vector;   -- Chatwoot requires pgvector

# Chatwoot -> existing Postgres
CHATWOOT_POSTGRES_HOST=host.docker.internal
CHATWOOT_POSTGRES_PORT=54321
CHATWOOT_POSTGRES_USERNAME=chatwoot
CHATWOOT_POSTGRES_PASSWORD=
CHATWOOT_POSTGRES_DATABASE=chatwoot
# Chatwoot -> existing Redis (pick a free logical DB index)
CHATWOOT_REDIS_URL=redis://host.docker.internal:6379/3

# Evolution -> existing Postgres + Redis (separate DB + index)
EVOLUTION_DATABASE_CONNECTION_URI=postgresql://evolution:CHANGEME@host.docker.internal:54321/evolution?schema=public
EVOLUTION_CACHE_REDIS_URI=redis://host.docker.internal:6379/4
